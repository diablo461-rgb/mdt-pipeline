# PostgreSQL
POSTGRES_USER=mdt_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=mdt_db

# n8n — локально
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
TIMEZONE=Europe/Berlin

# n8n auth
N8N_AUTH_USER=admin
N8N_AUTH_PASSWORD=your_strong_password_here

# Сгенерируй: openssl rand -hex 16
N8N_ENCRYPTION_KEY=your_32_char_key_here

# ── Hostinger (раскомментируй при деплое) ──
# N8N_HOST=n8n.yourdomain.com
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://n8n.yourdomain.com/

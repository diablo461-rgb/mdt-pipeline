# ── Calendar links for PDF button (week-specific ICS/webcal/google links) ───
# Если оставить пустым, pdf-service сам покажет страницу выбора календаря
# и даст пользователю выбрать сервис и время вручную.
CALENDAR_DEFAULT_URL=
CALENDAR_WEEK1_URL=
CALENDAR_WEEK2_URL=
CALENDAR_WEEK3_URL=
CALENDAR_WEEK4_URL=

# ── Paddle (вебхук endpoint регистрируется в Paddle Dashboard) ───────────────
